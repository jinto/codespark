#!/bin/bash
set -e

echo "🔨 Pre-push: building + all tests (including integration)..."

DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer \
xcodebuild -project apps/macos/CodeSpark.xcodeproj \
  -scheme CodeSpark \
  -configuration Debug \
  -destination 'platform=macOS,arch=arm64' \
  -quiet \
  build-for-testing

DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer \
xcodebuild -project apps/macos/CodeSpark.xcodeproj \
  -scheme CodeSpark \
  -configuration Debug \
  -destination 'platform=macOS,arch=arm64' \
  -quiet \
  test-without-building \
  -skip-testing:CodeSparkUITests

echo "✅ All tests passed (including integration)."
